<!-- Janus Purple Team Platform — Local Wazuh Detection Rules (WEAK / GAP STATE) -->
<!-- This file is the DEFAULT state deployed on Reset.                           -->
<!-- 2 rules MISSING: T1055 (100102), T1550.002 (100118)                         -->
<!-- 3 rules WEAKENED: T1027 (100105), T1071.001 (100124), T1486 (100116)        -->

<group name="local,sysmon,janus,windows,">

  <!-- ── T1059.001 — PowerShell from Abnormal Parent (Execution) ──────── -->
  <rule id="100100" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(cmd|wscript|cscript|mshta|rundll32|regsvr32|explorer)\.exe$</field>
    <description>T1059.001: Suspicious PowerShell launched from abnormal parent process</description>
    <group>sysmon_eid1_detections,janus_t1059_001,</group>
    <mitre><id>T1059.001</id></mitre>
  </rule>

  <!-- ── T1547.001 — Registry Run Key Persistence (Persistence) ───────── -->
  <rule id="100101" level="10">
    <if_sid>92300</if_sid>
    <description>T1547.001: Janus — Registry Run Key Persistence confirmed (CurrentVersion\Run write)</description>
    <group>sysmon_eid13_detections,janus_t1547_001,</group>
    <mitre><id>T1547.001</id></mitre>
  </rule>

  <!-- ── T1055 — RULE MISSING (no detection for process injection) ──────── -->
  <!-- Rule 100102 intentionally absent — gap for presentation               -->

  <!-- ── T1134 — Access Token Manipulation (Privilege Escalation) ──────── -->
  <rule id="100103" level="8">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\whoami\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(/priv|/all)</field>
    <description>T1134: Access Token Manipulation — whoami privilege enumeration</description>
    <group>sysmon_eid1_detections,janus_t1134,</group>
    <mitre><id>T1134</id></mitre>
  </rule>

  <rule id="100119" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(incognito|juicy.potato|sweet.potato|print.spoofer)\.exe$</field>
    <description>T1134: Known token impersonation tool executed</description>
    <group>sysmon_eid1_detections,janus_t1134,</group>
    <mitre><id>T1134</id></mitre>
  </rule>

  <!-- ── T1562.001 — Disable Security Tools (Defense Evasion) CRITICAL ── -->
  <rule id="100104" level="14">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)Set-MpPreference.*(Disable(RealtimeMonitoring|BehaviorMonitoring|IOAVProtection|AntivirusProtection))</field>
    <description>T1562.001: Windows Defender disabled via PowerShell Set-MpPreference</description>
    <group>sysmon_eid1_detections,janus_t1562_001,</group>
    <mitre><id>T1562.001</id></mitre>
  </rule>

  <rule id="100120" level="14">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)stop\s+(WinDefend|SecurityHealthService)</field>
    <description>T1562.001: Windows Defender service stopped via sc.exe</description>
    <group>sysmon_eid1_detections,janus_t1562_001,</group>
    <mitre><id>T1562.001</id></mitre>
  </rule>

  <!-- ── T1027 — WEAK: only catches classic -EncodedCommand, misses new obfuscation variants ─ -->
  <rule id="100105" level="8">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(powershell|pwsh)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(\-EncodedCommand)</field>
    <description>T1027: Obfuscated PowerShell — classic EncodedCommand flag only (incomplete coverage)</description>
    <group>sysmon_eid1_detections,janus_t1027,</group>
    <mitre><id>T1027</id></mitre>
  </rule>

  <!-- ── T1112 — Modify Registry (Defense Evasion) ─────────────────────── -->
  <rule id="100106" level="8">
    <if_group>sysmon_event_13</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\SOFTWARE\\(Microsoft\\Windows\\CurrentVersion\\Policies|Microsoft\\Windows NT\\CurrentVersion\\Image File Execution Options|Policies\\Microsoft\\Windows Defender)</field>
    <description>T1112: Suspicious registry modification of security or policy key</description>
    <group>sysmon_eid13_detections,janus_t1112,</group>
    <mitre><id>T1112</id></mitre>
  </rule>

  <rule id="100122" level="6">
    <if_group>sysmon_event_13</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(reg|powershell|pwsh)\.exe$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\(SOFTWARE|SYSTEM)\\</field>
    <description>T1112: Registry modification via command-line tool (reg.exe or PowerShell)</description>
    <group>sysmon_eid13_detections,janus_t1112,</group>
    <mitre><id>T1112</id></mitre>
  </rule>

  <!-- ── T1003.001 — LSASS Dump / Mimikatz (Credential Access) ─────────── -->
  <rule id="100107" level="14">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(procdump.*lsass|mimikatz|sekurlsa|lsadump)</field>
    <description>T1003.001: LSASS credential dumping tool detected in command line</description>
    <group>sysmon_eid1_detections,janus_t1003_001,</group>
    <mitre><id>T1003.001</id></mitre>
  </rule>

  <!-- ── T1082 — System Information Discovery (Discovery) ─────────────── -->
  <rule id="100108" level="4">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(systeminfo|hostname)\.exe$</field>
    <description>T1082: System Information Discovery via systeminfo or hostname</description>
    <group>sysmon_eid1_detections,janus_t1082,</group>
    <mitre><id>T1082</id></mitre>
  </rule>

  <!-- ── T1083 — File and Directory Discovery (Discovery) ──────────────── -->
  <rule id="100109" level="4">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(dir\s+/[bs]|tree\s+/f|Get-ChildItem.*-Recurse|gci\s+.*-rec)</field>
    <description>T1083: File and Directory Discovery via recursive directory listing</description>
    <group>sysmon_eid1_detections,janus_t1083,</group>
    <mitre><id>T1083</id></mitre>
  </rule>

  <!-- ── T1069.001 — Local Groups Discovery (Discovery) ────────────────── -->
  <rule id="100110" level="4">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\net1?\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)localgroup</field>
    <description>T1069.001: Local Permission Group Discovery via net localgroup</description>
    <group>sysmon_eid1_detections,janus_t1069_001,</group>
    <mitre><id>T1069.001</id></mitre>
  </rule>

  <!-- ── T1016 — Network Configuration Discovery (Discovery) ───────────── -->
  <rule id="100111" level="3">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(ipconfig|arp|route|netstat|nbtstat)\.exe$</field>
    <description>T1016: Network Configuration Discovery via built-in Windows networking tools</description>
    <group>sysmon_eid1_detections,janus_t1016,</group>
    <mitre><id>T1016</id></mitre>
  </rule>

  <rule id="100123" level="5">
    <if_group>sysmon_eid1_detections</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\cmd\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(ipconfig|arp\s+-[an]|route\s+print|netstat|nbtstat)</field>
    <description>T1016: Network Configuration Discovery — cmd.exe launched with network enumeration commands</description>
    <group>sysmon_eid1_detections,janus_t1016,</group>
    <mitre><id>T1016</id></mitre>
  </rule>

  <!-- ── T1018 — Remote System Discovery (Discovery) ───────────────────── -->
  <rule id="100112" level="5">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\net1?\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\bview\b</field>
    <description>T1018: Remote System Discovery via net view</description>
    <group>sysmon_eid1_detections,janus_t1018,</group>
    <mitre><id>T1018</id></mitre>
  </rule>

  <!-- ── T1550.002 — RULE MISSING (no detection for pass-the-hash) ──────── -->
  <!-- Rule 100118 intentionally absent — gap for presentation               -->

  <!-- ── T1048 — Exfiltration over Alternative Protocol (Exfiltration) ── -->
  <rule id="100113" level="10">
    <if_group>sysmon_event3</if_group>
    <field name="win.eventdata.destinationPort" type="pcre2">^(21|22|4444|6666|6667|8443|9001|1337)$</field>
    <field name="win.eventdata.image" type="pcre2" negate="yes">(?i)\\(chrome|firefox|msedge|iexplore|opera|brave|filezilla|winscp)\.exe$</field>
    <description>T1048: Possible data exfiltration over non-standard port from non-browser process</description>
    <group>sysmon_eid3_detections,janus_t1048,</group>
    <mitre><id>T1048</id></mitre>
  </rule>

  <!-- ── T1070.004 — Indicator Removal: File Deletion (Defense Evasion) ─ -->
  <rule id="100114" level="6">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\cmd\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(del\s+/f|rd\s+/s\s+/q|rmdir\s+/s)</field>
    <description>T1070.004: Indicator Removal via forced file deletion command</description>
    <group>sysmon_eid1_detections,janus_t1070_004,</group>
    <mitre><id>T1070.004</id></mitre>
  </rule>

  <!-- ── T1490 — Shadow Copy Deletion (Impact) CRITICAL ───────────────── -->
  <rule id="100115" level="15">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\vssadmin\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)delete\s+shadows</field>
    <description>T1490: Shadow Copy Deletion via vssadmin — ransomware pre-encryption step</description>
    <group>sysmon_eid1_detections,janus_t1490,</group>
    <mitre><id>T1490</id></mitre>
  </rule>

  <!-- ── T1486 — WEAK: misses PowerShell marker, only catches raw XOR bytes ─ -->
  <rule id="100116" level="14">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-bxor|WriteAllBytes)</field>
    <description>T1486: Ransomware — raw byte-level XOR encryption only (misses script-based variants)</description>
    <group>sysmon_eid1_detections,janus_t1486,</group>
    <mitre><id>T1486</id></mitre>
  </rule>

  <!-- ── T1566.001 — Spearphishing Attachment (Initial Access) ─────────── -->
  <rule id="100117" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)invoice_janus\.docm</field>
    <description>T1566.001: Spearphishing attachment dropped -invoice_janus.docm written via command line</description>
    <group>sysmon_eid1_detections,janus_t1566_001,</group>
    <mitre><id>T1566.001</id></mitre>
  </rule>

  <!-- ── T1071.001 — WEAK: only matches curl/wget, misses PowerShell C2 beacons ─ -->
  <rule id="100124" level="9">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(curl|wget)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(Invoke-WebRequest)</field>
    <description>T1071.001: HTTP C2 — curl/wget only (misses PowerShell-based beacons)</description>
    <group>sysmon_eid1_detections,janus_t1071_001,</group>
    <mitre><id>T1071.001</id></mitre>
  </rule>

  <!-- T1048 - Alternative protocol emulation through a raw TCP client -->
  <rule id="100125" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(powershell|pwsh)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(janus_t1048|TcpClient|Sockets\.TcpClient).*(exfil|Connect|21|22|4444|6667|8443|9001|1337)</field>
    <description>T1048: Alternative protocol transfer via raw TCP client or janus exfil marker</description>
    <group>sysmon_eid1_detections,janus_t1048,</group>
    <mitre><id>T1048</id></mitre>
  </rule>

</group>
